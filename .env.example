# Canonical production origin. Keep this identical in the Vite build,
# sitemap, robots.txt, Search Console, Bing Webmaster Tools, and GA4.
VITE_SITE_URL=https://morphos-ja.pages.dev

# Public measurement/configuration identifiers. Never put account passwords,
# API credentials, DNS tokens, or private keys in this file.
VITE_GA4_MEASUREMENT_ID=

# Optional URL-prefix verification tags. Prefer DNS verification for a
# Search Console Domain property. Leave empty when DNS/import is used.
VITE_GOOGLE_SITE_VERIFICATION=
VITE_BING_SITE_VERIFICATION=
