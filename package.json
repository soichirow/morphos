{
  "name": "morphos-ja",
  "private": true,
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "build:cloudflare": "npm run build && node scripts/prepare-cloudflare.mjs",
    "deploy": "npm run build:cloudflare && wrangler pages deploy .output/public --project-name=morphos-ja --branch=main",
    "preview": "vite preview",
    "preview:test": "wrangler pages dev .output/public --ip 127.0.0.1 --port 4173",
    "prepare": "husky",
    "check": "npm run lint && npm run typecheck",
    "ci": "npm run check && npm run test && npm run generate:catalog:check && npm run validate:catalog && npm run build:cloudflare && npm run test:e2e",
    "precommit": "bun run precommit:previews && bun run check",
    "precommit:previews": "node scripts/precommit-previews.mjs",
    "generate:catalog": "node scripts/generate-catalog.mjs",
    "generate:catalog:check": "node scripts/generate-catalog.mjs --check",
    "prepare:gentle-images": "node scripts/prepare-gentle-image-orders.ts",
    "generate:previews": "uv run python scripts/generate-previews.py",
    "render:og": "node scripts/render-og-image.mjs",
    "validate:catalog": "node scripts/validate-catalog.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit",
    "test:e2e:critical": "playwright test --grep-invert @upstream",
    "test:e2e:upstream": "playwright test --grep @upstream"
  },
  "knip": {
    "ignore": [
      "eslint.config.js",
      "scripts/test-docx.mjs",
      "public/systems/**/theme.css",
      "public/systems/**/generate-bundle.mjs"
    ]
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/react-router-ssr-query": "^1.166.9",
    "@tanstack/react-start": "^1.166.15",
    "@tanstack/router-plugin": "^1.166.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "nitro": "latest",
    "pptxgenjs": "^4.0.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.110.0"
  }
}
